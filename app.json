{
  "expo": {
    "name": "Un Pique",
    "slug": "un-pique",
    "owner": "seba-p1",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "transpilePackages": [
      "lucide-react-native",
      "lucide-react",
      "nativewind",
      "react-native-reanimated",
      "zustand",
      "@tanstack/react-query",
      "use-latest-callback",
      "react-native-tab-view"
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35"
        }
      ]
    ],
    "scheme": "unpique",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unpique.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.unpique.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "e714e944-b2a1-49a0-b417-997fe1fd9d34"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}